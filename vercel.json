{
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/canvaskit/(.*)", "destination": "/canvaskit/$1" },
    { "source": "/manifest.json", "destination": "/manifest.json" },
    { "source": "/favicon.png", "destination": "/favicon.png" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}