enum ProposalLayoutStyle { classic, splitHero, minimal }

class _HeroFeature extends StatelessWidget {
  final String text;

  const _HeroFeature({required this.text});

  @override
  Widget build(BuildContext context) {
    return Padding(
      padding: const EdgeInsets.only(bottom: 8),
      child: Row(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          const Icon(Icons.check_circle, size: 16, color: cGreen600),
          const SizedBox(width: 8),
          Expanded(
            child: Text(
              text,
              style: const TextStyle(
                fontSize: 13,
                fontWeight: FontWeight.w600,
                color: cGray800,
              ),
            ),
          ),
        ],
      ),
    );
  }
}

String layoutStyleLabel(ProposalLayoutStyle style) {
  switch (style) {
    case ProposalLayoutStyle.splitHero:
      return 'Split hero';
    case ProposalLayoutStyle.minimal:
      return 'Minimal';
    case ProposalLayoutStyle.classic:
    default:
      return 'Classic';
  }
}

