  'Mobile app included',
];

class ProposalTemplate {
  final String id;
  final String name;
  final String tagline;
  final List<String> tags;
  final IconData icon;
  final List<Color> previewGradient;
  final Map<String, dynamic> theme;
  final ProposalLayoutStyle layoutStyle;
  final List<String> heroHighlights;
  final List<String> heroStats;

  const ProposalTemplate({
    required this.id,
    required this.name,
    required this.tagline,
    required this.tags,
    required this.icon,
    required this.previewGradient,
    required this.theme,
    this.layoutStyle = ProposalLayoutStyle.classic,
    this.heroHighlights = kDefaultHeroHighlights,
    this.heroStats = kDefaultHeroStats,
  });
}

