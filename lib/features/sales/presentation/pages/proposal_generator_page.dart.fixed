    ).format(DateTime.now().add(const Duration(days: 5)));
    final theme = _getThemeColors();
    final ProposalTemplate template = selectedTemplate;
    final Color secondaryColor = theme['secondary'] as Color? ?? cBlue600;
    final Color lightBg1 = theme['lightBg1'] as Color? ?? cBlue50;
    final Color lightBorder = theme['lightBorder'] as Color? ?? cBlue200;

    return Scaffold(
      backgroundColor: cGray100,
      body: Column(
        children: [
          // HEADER (Matches sticky top-0 border-b-2 border-blue-600)
